<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>DemaConsulting.ApiMark.MSBuild</id>
    <version>0.1.0</version>
    <title>ApiMark MSBuild</title>
    <authors>DEMA Consulting</authors>
    <license type="expression">MIT</license>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <icon>Icon.png</icon>
    <readme>README.md</readme>
    <projectUrl>https://github.com/DemaConsulting/ApiMark</projectUrl>
    <description>MSBuild task that integrates ApiMark API documentation generation into .csproj and .vcxproj builds.</description>
    <copyright>Copyright DEMA Consulting</copyright>
    <tags>apimark msbuild api documentation markdown dotnet</tags>
    <repository type="git" url="https://github.com/DemaConsulting/ApiMark" branch="refs/heads/main" commit="0316f3a4eeb2799550026d0ca398445b9ebfb84e" />
    <dependencies>
      <group targetFramework=".NETStandard2.0">
        <dependency id="Microsoft.Build.Framework" version="17.8.43" exclude="Runtime,Build,Analyzers" />
        <dependency id="Microsoft.Build.Utilities.Core" version="17.8.43" exclude="Runtime,Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
</package>