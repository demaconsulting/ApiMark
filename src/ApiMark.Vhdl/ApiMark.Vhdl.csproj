<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <AssemblyName>ApiMark.Vhdl</AssemblyName>
    <RootNamespace>ApiMark.Vhdl</RootNamespace>
    <IsPackable>false</IsPackable>
    <Description>Generates API documentation from VHDL source files.</Description>
    <Authors>DEMA Consulting</Authors>
    <Company>DEMA Consulting</Company>
  </PropertyGroup>
  <PropertyGroup>
    <!-- Suppress warnings from ANTLR4-generated files that cannot be avoided without
         editing generated code. These diagnostics have no impact on hand-written code:
         CS1041/CS1658 - grammar rule named 'base' conflicts with C# keyword
         CS1584        - XML doc cref attribute references the same 'base' rule
         CS3021        - CLSCompliant attributes without assembly-level attribute -->
    <NoWarn>CS1041;CS1584;CS1658;CS3021</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <EmbeddedResource Include="VhdlAst\Antlr\*.interp" />
    <EmbeddedResource Include="VhdlAst\Antlr\*.tokens" />
  </ItemGroup>
  <ItemGroup>
    <Compile Update="VhdlAst\Antlr\*.cs">
      <NoWarn>CS1041;CS1584;CS1658;CS3021</NoWarn>
    </Compile>
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Antlr4.Runtime.Standard" Version="4.13.1" />
    <PackageReference Include="Microsoft.Extensions.FileSystemGlobbing" Version="8.0.0" />
  </ItemGroup>
  <ItemGroup>
    <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleTo">
      <_Parameter1>ApiMark.Vhdl.Tests</_Parameter1>
    </AssemblyAttribute>
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.NetAnalyzers" Version="10.0.300">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="SonarAnalyzer.CSharp" Version="10.26.0.140279">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\ApiMark.Core\ApiMark.Core.csproj" />
  </ItemGroup>
</Project>
