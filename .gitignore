# .gitignore
# Covers C# and common tools for the ApiMark project.

# Build outputs
bin/
obj/
artifacts/
test/packages/

# NuGet package caches under test fixtures
**/Fixtures/**/packages/

# Test results
**/TestResults/

# .NET
*.user
*.suo
.vs/
*.slnx.user

# Python virtual environment
.venv/

# Node
node_modules/
/package-lock.json

# Generated compliance documents (build outputs — never committed)
**/generated/

# Generated API documentation output (written by ApiMark; never committed)
output/
**/api-gradual/
**/api-single/
**/api/

# Agent logs
.agent-logs/

# OS
.DS_Store
Thumbs.db
